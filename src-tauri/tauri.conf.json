{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kairos",
  "version": "1.1.0",
  "identifier": "com.osklc.kairos",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kairos: Screen Time Tracker",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/osklc/kairos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCNUU4MDRFMEJBMThBMzAKUldRd2lxRUxUb0JleTYycmRrUldBNXFTWFJWb3dIZnMyYlpBUmYyT29DQ2k5T2YxQ0ZFZWYzUWkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "assets/sounds/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}